+/*
+ * Persistent Tesseract worker manager.
+ *
+ * IMPORTANT FIX: `Tesseract.recognize(image, lang, options)` (the one-shot
+ * convenience function) only forwards `options` to `createWorker()` — it does
+ * NOT apply OCR engine parameters like `tessedit_pageseg_mode`,
+ * `user_defined_dpi`, `tessedit_char_whitelist` or `tessedit_do_invert`.
+ * Those can only be applied via `worker.setParameters()` on an actual worker
+ * instance. Previously every single OCR pass (each preprocessing mode/preset
+ * defines its own `psm`/`dpi`) silently ran with Tesseract's default
+ * settings, so all the "document/ticket/table/screenshot" presets were
+ * producing near-identical engine behaviour and only differed by the canvas
+ * preprocessing — which is the main reason results looked inconsistent and
+ * "garbled" regardless of which mode was picked.
+ *
+ * On top of that, the one-shot API creates a brand new worker (and
+ * reinitializes the Thai+English language data) for every call, which is
+ * also why scanning with many passes was so slow. Keeping one worker alive
+ * per language and reusing it across passes fixes both problems.
+ */
+const OcrWorkerManager=(()=>{
+  let worker=null;
+  let workerLang=null;
+  let initPromise=null;
+  const progressCtx={start:0,end:100,label:''};
+
+  async function get(lang){
+    if(worker&&workerLang===lang)return worker;
+    if(initPromise)await initPromise.catch(()=>{});
+    if(worker&&workerLang===lang)return worker;
+    if(worker){
+      const stale=worker;
+      worker=null;
+      try{await stale.terminate();}catch(error){/* ignore */}
+    }
+    if(!window.Tesseract||typeof Tesseract.createWorker!=='function'){
+      throw new Error('โหลด Tesseract.js ไม่สำเร็จ กรุณาต่ออินเทอร์เน็ต');
+    }
+    initPromise=Tesseract.createWorker(lang,undefined,{
+      logger:m=>{
+        if(m.progress!==undefined)setProgress(progressCtx.start+(m.progress*(progressCtx.end-progressCtx.start)));
+        if(m.status)setStatus(progressCtx.label+' · '+m.status+' '+Math.round((m.progress||0)*100)+'%');
+      }
+    });
+    worker=await initPromise;
+    workerLang=lang;
+    initPromise=null;
+    return worker;
+  }
+
+  function setProgressContext(start,end,label){
+    progressCtx.start=start;
+    progressCtx.end=end;
+    progressCtx.label=label;
+  }
+
+  async function terminate(){
+    if(!worker)return;
+    const stale=worker;
+    worker=null;
+    workerLang=null;
+    try{await stale.terminate();}catch(error){/* ignore */}
+  }
+
+  return {get,setProgressContext,terminate};
+})();
+
+if(typeof window!=='undefined'){
+  window.addEventListener('beforeunload',()=>{OcrWorkerManager.terminate();});
+}
