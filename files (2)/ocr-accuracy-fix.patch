-      if(m.status)setStatus(label+' · '+m.status+' '+Math.round((m.progress||0)*100)+'%');
-    },
-    tessedit_pageseg_mode:psm,
+  const whitelist=thaiLang?'':(extra.whitelist||'');
+  const worker=await OcrWorkerManager.get(lang);
+  OcrWorkerManager.setProgressContext(progressStart,progressEnd,label);
+  // Every parameter is set explicitly (including the "off" cases) on every
+  // pass because the worker now persists across passes/calls — anything left
